FITNOTES_IMAGE_TAG=main
POSTGRES_USER=fitnotes
POSTGRES_DB=fitnotes
POSTGRES_PASSWORD=change-this-postgres-password
JWT_SECRET=change-this-jwt-secret
POSTGRES_DATA_DIR=/mnt/docker/volumes/fitnotes/postgres
FRONTEND_URL=https://fitnotes.adventureintandem.com
WITHINGS_CLIENT_ID=replace-withings-client-id
WITHINGS_CLIENT_SECRET=replace-withings-client-secret
WITHINGS_REDIRECT_URI=https://fitnotes.adventureintandem.com/api/withings/callback
WITHINGS_WEBHOOK_URL=https://fitnotes.adventureintandem.com/api/withings/webhook
WITHINGS_WEBHOOK_SECRET=replace-withings-webhook-secret
