{
  "identifier": "com.fitnotes.reborn.app",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "FitNotes",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Sports",
    "copyright": "Copyright © 2026 FitNotes Reborn",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "Premium multi-user offline-first workout logger matching original FitNotes Android APK functionality.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "resources": [],
    "shortDescription": "Premium workout tracker",
    "targets": "all"
  },
  "productName": "FitNotes",
  "version": "0.1.0",
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": ["fitnotes"]
        }
      ],
      "desktop": {
        "schemes": ["fitnotes"]
      }
    }
  }
}
